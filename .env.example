# ============================================================
# 方式一：OpenAI 官方 API
# ============================================================
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o
# LLM_PROVIDER=openai

# ============================================================
# 方式二：DeepSeek API（推荐，便宜、中文好、OpenAI 兼容）
#   注册获取 key: https://platform.deepseek.com
# ============================================================
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat
LLM_PROVIDER=openai

# ============================================================
# 方式三：Ollama 本地模型（免费，需先装 Ollama + 拉模型）
#   安装: https://ollama.com
#   拉模型: ollama pull qwen2.5:7b
#   然后取消下面三行注释，注释掉上面三行
# ============================================================
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# 浏览器模式（false = 可见窗口，true = 无头模式）
BROWSER_HEADLESS=false
# 浏览器渠道: 留空=Playwright自带Chromium | msedge=本机Edge | chrome=本机Chrome
BROWSER_CHANNEL=msedge
